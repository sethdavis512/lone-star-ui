{
    "name": "lone-star-ui",
    "version": "0.8.3",
    "module": "index.ts",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./button": {
            "import": "./dist/components/Button/index.js",
            "types": "./dist/components/Button/index.d.ts"
        },
        "./styles": "./dist/styles.css"
    },
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "./dist/styles.css"
    ],
    "files": [
        "dist"
    ],
    "private": false,
    "license": "MIT",
    "description": "A React 19 component library built with TypeScript, Tailwind CSS 4, and CVA. Publishes ESM-only to npm with full type declarations.",
    "author": "Seth Davis",
    "homepage": "https://sethdavis512.github.io/lone-star-ui",
    "repository": {
        "type": "git",
        "url": "https://github.com/sethdavis512/lone-star-ui.git"
    },
    "bugs": {
        "url": "https://github.com/sethdavis512/lone-star-ui/issues"
    },
    "keywords": [
        "react",
        "component-library",
        "tailwindcss",
        "typescript",
        "ui",
        "design-system",
        "cva",
        "base-ui",
        "accessible"
    ],
    "scripts": {
        "build-storybook": "storybook build",
        "build": "bun run build.ts && tsc",
        "dev": "bun run build.ts --watch",
        "prepublishOnly": "bun run build",
        "storybook": "storybook dev -p 6006",
        "typecheck": "tsc --noEmit",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "bun run build && changeset publish"
    },
    "dependencies": {
        "@base-ui/react": "^1.2.0",
        "clsx": "^2.1.1",
        "cva": "^1.0.0-beta.4",
        "tailwind-merge": "^3.0.2"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@chromatic-com/storybook": "^5.0.1",
        "@storybook/addon-a11y": "^10.2.14",
        "@storybook/addon-docs": "^10.2.14",
        "@storybook/addon-onboarding": "^10.2.14",
        "@storybook/addon-themes": "^10.2.15",
        "@storybook/addon-vitest": "^10.2.14",
        "@storybook/react-vite": "^10.2.14",
        "@tailwindcss/cli": "^4.2.1",
        "@tailwindcss/vite": "^4.2.1",
        "@types/bun": "latest",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/browser-playwright": "^4.0.18",
        "@vitest/coverage-v8": "^4.0.18",
        "playwright": "^1.58.2",
        "storybook": "^10.2.14",
        "tailwindcss": "^4.2.1",
        "typescript": "^5",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "typescript": "^5",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "@base-ui/react": "^1.0.0"
    }
}
